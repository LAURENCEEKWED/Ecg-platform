# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (SQLite for demo — replace with PostgreSQL in production)
DB_PATH=./data/ecg_platform.db

# ECG Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50mb

# Alert Settings
HIGH_RISK_THRESHOLD=67
WARNING_RISK_THRESHOLD=34

# Email Configuration (for real emails)
# For Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM="ECG Platform" <your-email@gmail.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# SMS Configuration (for real SMS via Twilio)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1234567890
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# CORS
FRONTEND_URL=http://localhost:3000

# Hospital API Key (for testing)
HOSPITAL_API_KEY=HOSPITAL_TEST_KEY_2024
