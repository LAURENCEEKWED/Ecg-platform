{
  "name": "ecg-hospital-client",
  "version": "1.0.0",
  "description": "Hospital ECG machine integration client — simulates ECG transmission to the platform",
  "main": "hospital-client.js",
  "scripts": {
    "send": "node hospital-client.js",
    "send:normal": "node hospital-client.js --rhythm NORMAL",
    "send:afib": "node hospital-client.js --rhythm AFIB",
    "send:tachy": "node hospital-client.js --rhythm TACHYCARDIA",
    "send:brady": "node hospital-client.js --rhythm BRADYCARDIA",
    "send:pvc": "node hospital-client.js --rhythm PVC",
    "loop": "node loop-sender.js"
  }
}
